# Claude Auto-Debug user configuration
#
# Copy or install this file to:
#   ~/.config/claude-auto-debug/config.env
#
# Both quoted and unquoted values are accepted.
# The installer writes unquoted KEY=value format.

# Required: absolute path to the project that auto-debug should operate on.
PROJECT_DIR=

# Validation command run after Claude makes changes.
VALIDATION_CMD=bash scripts/run-tests.sh

# Comma-separated tool allowlist passed to claude -p --allowedTools.
ALLOWED_TOOLS=Read,Edit,Write,Glob,Grep,Bash

# Maximum number of files Claude may modify in a single run.
MAX_FILES=3

# Number of days to retain run logs before auto-cleanup.
LOG_RETENTION_DAYS=30

# Timer interval for systemd (used by install.sh to render the timer unit).
INTERVAL=6h
